generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LIDER
  HOLDER
  CAJERO
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum CurrencyCode {
  ROBUX
  COP
  USD
}

/// Cómo prefiere recibir el pago el solicitante (datos en paymentMethodDetail).
enum PaymentMethod {
  BANK
  ROBLOX
  PAYPAL
}

enum IncomeCustomerType {
  CLIENTE
  DESTACADO
  RICACHON
}

enum IncomePaymentMethod {
  NEQUI
  DAVIPLATA
  BANCOLOMBIA
  PAYPAL
  OTRO
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(LIDER)
  avatar        String?
  telegramId    String?   @unique
  /// Solo holders con este flag pueden generar código y vincular Telegram (emparejamiento con la cuenta).
  telegramPairingAllowed Boolean @default(false)
  isActive      Boolean   @default(true)
  emailNotifications Boolean @default(true)
  inAppNotifications Boolean @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  paymentRequests PaymentRequest[]
  approvals      PaymentApproval[]
  meetingsAsLeader Meeting[] @relation("LeaderMeetings")
  meetingsAsHolder Meeting[] @relation("HolderMeetings")
  auditLogs       AuditLog[]
  notifications   Notification[]
  budgets         Budget[]
  chatConversationsLow  ChatConversation[] @relation("ChatConvLow")
  chatConversationsHigh ChatConversation[] @relation("ChatConvHigh")
  chatMessagesSent      ChatMessage[]
  chatReads             ChatConversationRead[]
  incomeRecords         IncomeRecord[]
}

/// Conversación 1:1; participantLowId & participantHighId ordenados lexicográficamente (id cuid).
model ChatConversation {
  id                String   @id @default(cuid())
  participantLowId  String
  participantHighId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  participantLow  User @relation("ChatConvLow", fields: [participantLowId], references: [id], onDelete: Cascade)
  participantHigh User @relation("ChatConvHigh", fields: [participantHighId], references: [id], onDelete: Cascade)
  messages        ChatMessage[]
  reads           ChatConversationRead[]

  @@unique([participantLowId, participantHighId])
}

model ChatConversationRead {
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @db.Text
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model PaymentRequest {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(12, 2)
  currency    CurrencyCode  @default(COP)
  concept     String
  description String        @db.Text
  category    String
  requiredDate DateTime
  status      PaymentStatus @default(PENDING)
  rejectionComment String?   @db.Text
  paymentProofUrl String?    @db.Text
  /// Transferencia bancaria, Roblox o PayPal (ver paymentMethodDetail).
  paymentMethod       PaymentMethod?
  paymentMethodDetail String?        @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  approvedAt  DateTime?
  paidAt      DateTime?

  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  approvedBy  String?
  paidBy      String?

  evidences   Evidence[]
  auditLogs   AuditLog[]
  timeline    PaymentTimeline[]
  approvals   PaymentApproval[]
}

model Evidence {
  id        String   @id @default(cuid())
  filename  String
  filepath  String
  mimetype  String
  size      Int
  createdAt DateTime @default(now())

  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)
}

model Meeting {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  scheduledAt DateTime
  status      MeetingStatus @default(PENDING)
  meetingUrl  String?
  /// Set when a 15-minute reminder was sent (in-app + optional Telegram)
  reminderSentAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  leaderId    String
  leader      User          @relation("LeaderMeetings", fields: [leaderId], references: [id], onDelete: Cascade)
  holderId    String
  holder      User          @relation("HolderMeetings", fields: [holderId], references: [id])
  auditLogs   AuditLog[]
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  details    String   @db.Text
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  userId         String?
  user           User?   @relation(fields: [userId], references: [id])
  paymentRequestId String?
  paymentRequest   PaymentRequest? @relation(fields: [paymentRequestId], references: [id])
  meetingId      String?
  meeting        Meeting? @relation(fields: [meetingId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String   @db.Text
  /// Ruta interna de la app (ej. /meetings) para abrir al hacer clic.
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId    String
}

model PaymentTimeline {
  id              String        @id @default(cuid())
  paymentRequestId String
  paymentRequest   PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)
  status          PaymentStatus
  comment         String?       @db.Text
  createdAt       DateTime      @default(now())

  changedBy        String?
}

model Budget {
  id          String    @id @default(cuid())
  name        String
  amount      Decimal   @db.Decimal(12, 2)
  period      String    @default("monthly")
  startDate   DateTime
  endDate     DateTime
  category    String?
  leaderId    String?
  leader      User?      @relation(fields: [leaderId], references: [id], onDelete: SetNull)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  thresholds  Int[]     @default([70, 90, 100])
  alerts      BudgetAlert[]
}

model BudgetAlert {
  id          String   @id @default(cuid())
  budgetId    String
  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  threshold   Int
  sentAt      DateTime @default(now())
  type        String
}

model ApprovalRule {
  id              String   @id @default(cuid())
  name            String
  minAmount       Decimal  @db.Decimal(12, 2)
  maxAmount       Decimal? @db.Decimal(12, 2)
  requiredApprovals Int    @default(1)
  approverRoles   String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PaymentApproval {
  id              String   @id @default(cuid())
  paymentRequestId String
  paymentRequest  PaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)
  approverId      String
  approver        User     @relation(fields: [approverId], references: [id])
  status          ApprovalStatus @default(PENDING)
  comment         String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model SlaRule {
  id              String   @id @default(cuid())
  name            String
  status          String
  maxHours        Int
  escalationRole  String?
  notifyTemplate  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model IncomeRecord {
  id                 String              @id @default(cuid())
  date               DateTime
  customerType       IncomeCustomerType
  paymentMethod      IncomePaymentMethod
  paymentMethodOther String?
  currency           CurrencyCode        @default(COP)
  digitalService     String
  soldAmount         Decimal             @db.Decimal(12, 2)
  receivedAmount     Decimal             @db.Decimal(12, 2)
  note               String?             @db.Text
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  createdById        String
  createdBy          User                @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([customerType])
  @@index([paymentMethod])
  @@index([digitalService])
}
