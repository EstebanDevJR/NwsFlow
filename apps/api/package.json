{
  "name": "@paymentflow/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION=true vitest run",
    "lint": "tsc --noEmit",
    "db:generate": "npm run db:generate --workspace=@paymentflow/database",
    "db:push": "npm run db:push --workspace=@paymentflow/database",
    "db:validate": "npx prisma validate --schema=./packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@paymentflow/auth": "1.0.0",
    "@paymentflow/database": "1.0.0",
    "@paymentflow/shared": "1.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.8",
    "exceljs": "^4.4.0",
    "resend": "^4.0.1",
    "telegraf": "^4.16.3",
    "pino": "^9.5.0",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.4.1",
    "bullmq": "^5.28.3",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.17.3",
    "eslint": "^8.57.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "@types/cookie-parser": "^1.4.7",
    "pino-pretty": "^11.3.0"
  }
}
