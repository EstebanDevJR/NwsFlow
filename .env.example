# Database
DB_USER=paymentflow
DB_PASSWORD=change_me_in_production
DB_NAME=paymentflow

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# App
PORT=3000
NODE_ENV=production
FRONTEND_URL=http://localhost:3000
# URL pública base de la API (sin /api). Obligatoria si el navegador y la API están en distinto origen
# o detrás de nginx/HTTPS; las evidencias y avatars se enlazan con esta base.
# Ej. desarrollo: http://localhost:3000  |  producción: https://tudominio.com
API_PUBLIC_URL=http://localhost:3000
# Detrás de reverse proxy (nginx): 1 o true para que req.protocol y req.host sean correctos
TRUST_PROXY=false
# Carpeta donde se guardan archivos en disco (sin S3). En Docker suele montarse como volumen.
UPLOAD_DIR=uploads
# Set to true only to allow public self-registration of LIDER accounts
ALLOW_PUBLIC_REGISTRATION=false

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
BOT_API_URL=http://api:3000/api
BOT_INTERNAL_TOKEN=change_me_bot_internal_token

# Email (Resend — https://resend.com)
RESEND_API_KEY=
# Dominio verificado en Resend, ej. "NwSPayFlow <notificaciones@tudominio.com>"
# En pruebas puedes usar onboarding@resend.dev (solo a tu email de cuenta Resend)
RESEND_FROM=
# Compatibilidad: si RESEND_FROM está vacío, se usa SMTP_FROM (migración desde SMTP)
SMTP_FROM=

# Redis
REDIS_URL=redis://redis:6379

# S3 / MinIO (OPCIONAL — déjalo vacío para usar solo disco local en el servidor/droplet)
# Si no defines S3_ENDPOINT, S3_ACCESS_KEY y S3_SECRET_KEY, los archivos van a UPLOAD_DIR
# y se sirven en /uploads (volumen Docker recomendado en producción).
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=paymentflow
S3_FORCE_PATH_STYLE=true

# --- Frontend (build Vite; se inyecta en el JS estático) ---
# En producción: https://tudominio.com/api — debe coincidir con cómo el navegador llama a la API.
# También se usa como ARG en docker-compose.prod.yml al construir la imagen.
# VITE_API_URL=https://tudominio.com/api

# CORS: orígenes permitidos del navegador (separados por coma) o usa FRONTEND_URL por defecto
# CORS_ORIGINS=https://tudominio.com
